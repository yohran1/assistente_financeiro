# =============================================
# VARIÁVEIS DE AMBIENTE — COPIE PARA .env
# Nunca commitar o arquivo .env com valores reais
# =============================================

# SUPABASE — app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# SENTRY — sentry.io → Settings → Projects → Client Keys
VITE_SENTRY_DSN=https://SEU_DSN@sentry.io/SEU_ID

# NOME DO APP
VITE_APP_NAME=Assistente Financeiro

# =============================================
# EDGE FUNCTION: IA Proxy (configure no Supabase CLI)
# supabase secrets set GEMINI_API_KEY=sua_chave_aqui
# supabase secrets set GROQ_API_KEY=sua_chave_aqui
# supabase secrets set ALLOWED_ORIGIN=https://seu-dominio.com
# =============================================
# GEMINI_API_KEY - Obtenha em: https://ai.google.dev/tutorials/setup
# GROQ_API_KEY - Obtenha em: https://console.groq.com
# ALLOWED_ORIGIN - URL do seu domínio (ex: http://localhost:3000 para dev)
# SB_SERVICE_ROLE_KEY - Gerado automaticamente pelo Supabase (não editar)
# GROQ_API_KEY=sua_groq_key
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
